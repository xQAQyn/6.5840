{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch MapReduce Coordinator", // 配置名称，在调试下拉菜单中显示
            "type": "go",
            "request": "launch",
            "mode": "auto",
            // 1. 指定程序的入口文件
            "program": "${workspaceFolder}/src/main/mrcoordinator.go",
            // 2. 在这里填写你的命令行参数 (sock123 和 pg-*.txt)
            "args": [
                "sock123",
                "pg-being_ernest.txt",
                "pg-dorian_gray.txt",
                "pg-frankenstein.txt",
                "pg-grimm.txt",
                "pg-huckleberry_finn.txt",
                "pg-metamorphosis.txt",
                "pg-sherlock_holmes.txt",
                "pg-tom_sawyer.txt"
            ],
            // 3. 设置程序的工作目录 (通常是项目根目录)
            "cwd": "${workspaceFolder}/src/main",
            // 4. 让程序在VSCode的集成终端中运行，这样才能直接看到输出，也支持输入
            "console": "integratedTerminal",
            // 5. 如果需要环境变量，可在这里设置（可选）
            "env": {}
        },
        {
            "name": "Debug MapReduce Worker",
            "type": "go",
            "request": "launch",
            "mode": "exec", // 关键：执行已有二进制
            "program": "${workspaceFolder}/src/main/mrworker",
            "args": [
                "crash.so",
                "sock123"
            ],
            "cwd": "${workspaceFolder}/src/main",
            "console": "integratedTerminal",
            "preLaunchTask": "build all (plugin + worker)"
        },
        {
            "name": "Debug MapReduce Worker 1",
            "type": "go",
            "request": "launch",
            "mode": "exec",
            "program": "${workspaceFolder}/src/main/mrworker",
            "args": [
                "crash.so",
                "sock123"
            ],
            "cwd": "${workspaceFolder}/src/main",
            "console": "integratedTerminal",
            "preLaunchTask": "build all (plugin + worker)" // 保留在一个实例中确保编译即可
        },
        {
            "name": "Debug MapReduce Worker 2",
            "type": "go",
            "request": "launch",
            "mode": "exec",
            "program": "${workspaceFolder}/src/main/mrworker",
            "args": [
                "crash.so",
                "sock123"
            ],
            "cwd": "${workspaceFolder}/src/main",
            "console": "integratedTerminal"
            // 此处无需再写 preLaunchTask，避免重复触发编译
        },
        {
            "name": "Debug MapReduce Worker 3",
            "type": "go",
            "request": "launch",
            "mode": "exec",
            "program": "${workspaceFolder}/src/main/mrworker",
            "args": [
                "crash.so",
                "sock123"
            ],
            "cwd": "${workspaceFolder}/src/main",
            "console": "integratedTerminal"
            // 此处无需再写 preLaunchTask，避免重复触发编译
        }
    ],
    "compounds": [
        {
            "name": "Debug All Workers",
            "configurations": [
                "Debug MapReduce Worker 1",
                "Debug MapReduce Worker 2",
                "Debug MapReduce Worker 3"
            ],
            "stopAll": true
        }
    ]
}